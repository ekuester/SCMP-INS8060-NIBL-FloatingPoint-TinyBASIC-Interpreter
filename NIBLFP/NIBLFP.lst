      15/       0 :                     L FUNCTION VAL16, (VAL16 & 0xFF)
      16/       0 :                     H FUNCTION VAL16, ((VAL16 >> 8) & 0xFF)
      17/       0 :                     
      18/       0 :                     JS    MACRO  P,VAL            ;JUMP TO SUBROUTINE
      19/       0 :                             LDI  H(VAL-1)
      20/       0 :                             XPAH P
      21/       0 :                             LDI  L(VAL-1)
      22/       0 :                             XPAL P
      23/       0 :                             XPPC P
      24/       0 :                           ENDM
      25/       0 :                     
      26/       0 :                     LDPI  MACRO  P,VAL            ;LOAD POINTER
      27/       0 :                             LDI  L(VAL)
      28/       0 :                             XPAL P
      29/       0 :                             LDI  H(VAL)
      30/       0 :                             XPAH P
      31/       0 :                           ENDM
      32/       0 :                     
      33/       0 :                     CALL  MACRO  P,VAL            ;CALL SUBROUTINE
      34/       0 :                             XPPC P
      35/       0 :                             DB   H(VAL)
      36/       0 :                             DB   L(VAL)
      37/       0 :                           ENDM
      38/       0 :                     
      39/       0 :                     RTRN  MACRO  P,VAL            ;RETURN FROM SUBROUTINE
      40/       0 :                             XPPC P
      41/       0 :                             DB   0
      42/       0 :                           ENDM
      43/       0 :                     
